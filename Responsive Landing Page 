<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NovaAI - Responsive Multi Page Website</title>

<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:Arial, sans-serif;
background:#f5f7ff;
color:#222;
}

/* NAVBAR */

header{
background:linear-gradient(135deg,#4a6cf7,#6c63ff);
padding:18px 8%;
color:white;
}

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
}

.logo{
font-size:28px;
font-weight:bold;
}

nav a{
color:white;
text-decoration:none;
margin-left:20px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

nav a:hover{
opacity:0.8;
}

/* PAGES */

.page{
display:none;
padding:70px 8%;
min-height:100vh;
}

.active{
display:block;
}

/* HOME PAGE */

.hero{
display:flex;
justify-content:space-between;
align-items:center;
gap:40px;
flex-wrap:wrap;
}

.hero-text{
flex:1;
min-width:280px;
}

.hero-text h1{
font-size:52px;
margin-bottom:20px;
color:#4a6cf7;
}

.hero-text p{
font-size:18px;
margin-bottom:25px;
line-height:1.7;
}

.hero-btn{
display:inline-block;
padding:14px 28px;
background:#4a6cf7;
color:white;
text-decoration:none;
border-radius:8px;
font-weight:bold;
transition:0.3s;
}

.hero-btn:hover{
transform:translateY(-3px);
}

.hero-image{
flex:1;
text-align:center;
}

.hero-image img{
width:100%;
max-width:420px;
}

/* FEATURES */

.section-title{
text-align:center;
margin-bottom:50px;
}

.section-title h2{
font-size:38px;
color:#4a6cf7;
margin-bottom:10px;
}

.feature-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.feature-card{
background:white;
padding:30px;
border-radius:14px;
text-align:center;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
transition:0.3s;
}

.feature-card:hover{
transform:translateY(-8px);
}

.feature-card i{
font-size:55px;
color:#4a6cf7;
margin-bottom:20px;
}

/* TESTIMONIALS */

.testimonial-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.testimonial{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
}

.testimonial p{
font-style:italic;
margin-bottom:15px;
line-height:1.7;
}

.testimonial h4{
color:#4a6cf7;
}

/* CONTACT */

.contact-box{
max-width:700px;
margin:auto;
background:white;
padding:35px;
border-radius:14px;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
}

form input,
form textarea{
width:100%;
padding:14px;
margin:12px 0;
border:1px solid #ccc;
border-radius:8px;
font-size:16px;
}

form button{
padding:14px 25px;
border:none;
background:#4a6cf7;
color:white;
border-radius:8px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

form button:hover{
background:#3557e0;
}

/* FOOTER */

footer{
background:#111827;
color:white;
padding:25px;
text-align:center;
}

.social-icons a{
color:white;
font-size:30px;
margin:0 10px;
transition:0.3s;
}

.social-icons a:hover{
color:#6c63ff;
}

/* MOBILE */

@media(max-width:768px){

.navbar{
flex-direction:column;
gap:15px;
}

.hero{
text-align:center;
}

.hero-text h1{
font-size:38px;
}

nav a{
margin:0 10px;
}

}

</style>
</head>

<body>

<!-- HEADER -->

<header>

<div class="navbar">

<div class="logo">AI Productivity App</div>

<nav>
<a onclick="showPage('home')">Home</a>
<a onclick="showPage('features')">Features</a>
<a onclick="showPage('testimonials')">Testimonials</a>
<a onclick="showPage('contact')">Contact</a>
</nav>

</div>

</header>

<!-- HOME PAGE -->

<section id="home" class="page active">

<div class="hero">

<div class="hero-text">

<h1>AI Productivity App For Smarter Workflows</h1>

<p>
AI Productivity App helps students, professionals, and startups automate tasks, organize schedules, manage projects, and improve workflow efficiency using advanced artificial intelligence tools.
</p>

<a href="#" class="hero-btn">Start Free Trial</a>

</div>

<div class="hero-image">
<img src="https://cdn-icons-png.flaticon.com/512/4712/4712109.png" alt="AI">
</div>

</div>

</section>

<!-- FEATURES PAGE -->

<section id="features" class="page">

<div class="section-title">
<h2>Powerful AI Features</h2>
<p>Everything you need in one platform.</p>
</div>

<div class="feature-grid">

<div class="feature-card">
<i class='bx bx-brain'></i>
<h3>Smart Task Automation</h3>
<p>Automatically manage repetitive tasks and save valuable time using AI-powered workflows.</p>
</div>

<div class="feature-card">
<i class='bx bx-devices'></i>
<h3>Cross Platform Access</h3>
<p>Access your dashboard seamlessly on desktop, tablet, and mobile devices anytime.</p>
</div>

<div class="feature-card">
<i class='bx bx-line-chart'></i>
<h3>Productivity Analytics</h3>
<p>Track task completion, performance, and efficiency with real-time analytics.</p>
</div>

<div class="feature-card">
<i class='bx bx-shield'></i>
<h3>Cloud Security</h3>
<p>Keep your projects and personal data secure with encrypted cloud storage.</p>
</div>

</div>

</section>

<!-- TESTIMONIAL PAGE -->

<section id="testimonials" class="page">

<div class="section-title">
<h2>Testimonials</h2>
<p>See how users improved productivity using AI Productivity App.</p>
</div>

<div class="testimonial-grid">

<div class="testimonial">
<p>
“AI Productivity App helped our team organize projects and automate daily operations efficiently.”
</p>
<h4>- Rahul Sharma</h4>
</div>

<div class="testimonial">
<p>
“The AI-powered productivity tools are extremely useful for students and startup teams.”
</p>
<h4>- Sneha Reddy</h4>
</div>

<div class="testimonial">
<p>
“One of the best productivity platforms with modern UI and intelligent workflow management.”
</p>
<h4>- Arjun Patel</h4>
</div>

</div>

</section>

<!-- CONTACT PAGE -->

<section id="contact" class="page">

<div class="section-title">
<h2>Contact Us</h2>
<p>We would love to hear from you.</p>
</div>

<div class="contact-box">

<form>

<input type="text" placeholder="Enter Your Name" required>

<input type="email" placeholder="Enter Your Email" required>

<textarea rows="6" placeholder="Enter Your Message"></textarea>

<button type="submit">Send Message</button>

</form>

</div>

</section>

<!-- FOOTER -->

<footer>

<h3>AI Productivity App</h3>
<p>Smart AI Solutions For Better Productivity</p>

<br>

<div class="social-icons">
<a href="#"><i class='bx bxl-linkedin-square'></i></a>
<a href="#"><i class='bx bxl-github'></i></a>
<a href="#"><i class='bx bxl-instagram'></i></a>
</div>

<br>

<p>© 2026 AI Productivity App. All Rights Reserved.</p>

</footer>

<script>

/* MULTI PAGE NAVIGATION */

function showPage(page){

let pages=document.querySelectorAll('.page');

pages.forEach(p=>p.classList.remove('active'));

document.getElementById(page).classList.add('active');

window.scrollTo(0,0);

}

</script>

</body>
</html>