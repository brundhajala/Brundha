<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Smart Interactive Web Dashboard</title>

<style>

/* ---------- GLOBAL ---------- */

body{
font-family:Arial, Helvetica, sans-serif;
margin:0;
background:#f4f6fb;
color:#333;
}

h1,h2{
color:#2c3e50;
}

/* ---------- NAVBAR ---------- */

nav{
display:flex;
justify-content:space-between;
align-items:center;
background:#2c3e50;
color:white;
padding:15px 30px;
}

nav ul{
display:flex;
list-style:none;
padding:0;
margin:0;
}

nav li{
margin-left:20px;
cursor:pointer;
}

/* ---------- LAYOUT ---------- */

.container{
display:grid;
grid-template-columns:250px 1fr;
min-height:100vh;
}

/* ---------- SIDEBAR ---------- */

.sidebar{
background:#34495e;
color:white;
padding:20px;
}

.sidebar button{
display:block;
width:100%;
margin:10px 0;
padding:10px;
border:none;
background:#2ecc71;
color:white;
cursor:pointer;
border-radius:5px;
}

/* ---------- MAIN ---------- */

.main{
padding:30px;
}

.page{
display:none;
}

.active{
display:block;
}

/* ---------- CARDS ---------- */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 3px 8px rgba(0,0,0,0.1);
}

/* ---------- TODO ---------- */

#todo input{
padding:10px;
width:70%;
}

#todo button{
padding:10px;
background:#2ecc71;
border:none;
color:white;
cursor:pointer;
}

/* ---------- IMAGE GALLERY ---------- */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:20px;
}

.gallery img{
width:100%;
border-radius:10px;
}

/* ---------- RESPONSIVE ---------- */

@media(max-width:800px){

.container{
grid-template-columns:1fr;
}

.sidebar{
display:flex;
overflow-x:auto;
}

.sidebar button{
margin-right:10px;
}

}

</style>
</head>

<body>

<nav>

<h2>Smart Interactive Web Dashboard</h2>

<ul>
<li onclick="showPage('dashboard')">Dashboard</li>
<li onclick="showPage('todo')">To-Do</li>
<li onclick="showPage('gallery')">Gallery</li>
<li onclick="showPage('api')">Live API</li>
</ul>

</nav>


<div class="container">

<div class="sidebar">

<h3>Navigation</h3>

<button onclick="showPage('dashboard')">Dashboard</button>
<button onclick="showPage('todo')">Task Manager</button>
<button onclick="showPage('gallery')">Image Gallery</button>
<button onclick="showPage('api')">API Data</button>

</div>


<div class="main">

<!-- DASHBOARD -->

<section id="dashboard" class="page active">

<h1>Dashboard</h1>

<div class="cards">

<div class="card">
<h3>Project</h3>
<p>Smart Interactive Web Dashboard built using HTML, CSS and JavaScript.</p>
</div>

<div class="card">
<h3>Features</h3>
<p>Responsive UI, API integration, dynamic components, and optimized performance.</p>
</div>

<div class="card">
<h3>Technology</h3>
<p>HTML5, CSS Grid, Flexbox, JavaScript DOM Manipulation.</p>
</div>

</div>

</section>


<!-- TODO -->

<section id="todo" class="page">

<h1>Task Manager</h1>

<input id="taskInput" placeholder="Enter new task">

<button onclick="addTask()">Add</button>

<ul id="taskList"></ul>

</section>


<!-- GALLERY -->

<section id="gallery" class="page">

<h1>Image Gallery</h1>

<div class="gallery">

<img loading="lazy" src="https://picsum.photos/400/250?1">
<img loading="lazy" src="https://picsum.photos/400/250?2">
<img loading="lazy" src="https://picsum.photos/400/250?3">
<img loading="lazy" src="https://picsum.photos/400/250?4">

</div>

</section>


<!-- API -->

<section id="api" class="page">

<h1>Live API Data</h1>

<button onclick="getJoke()">Load Random Joke</button>

<p id="joke"></p>

</section>

</div>

</div>


<script>

/* ---------- PAGE NAVIGATION ---------- */

function showPage(page){

document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));

document.getElementById(page).classList.add("active");

}


/* ---------- TODO LIST ---------- */

let tasks = JSON.parse(localStorage.getItem("tasks")) || [];

function renderTasks(){

let list=document.getElementById("taskList");

list.innerHTML="";

tasks.forEach((task,index)=>{

let li=document.createElement("li");

li.textContent=task;

let btn=document.createElement("button");

btn.textContent="Delete";

btn.onclick=()=>{

tasks.splice(index,1);

localStorage.setItem("tasks",JSON.stringify(tasks));

renderTasks();

};

li.appendChild(btn);

list.appendChild(li);

});

}

function addTask(){

let input=document.getElementById("taskInput");

if(input.value==="") return;

tasks.push(input.value);

localStorage.setItem("tasks",JSON.stringify(tasks));

input.value="";

renderTasks();

}

renderTasks();


/* ---------- API FETCH ---------- */

function getJoke(){

fetch("https://official-joke-api.appspot.com/random_joke")

.then(res=>res.json())

.then(data=>{

document.getElementById("joke").innerText =
data.setup + " - " + data.punchline;

});

}

</script>

</body>
</html>